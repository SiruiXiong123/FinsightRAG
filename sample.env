GOOGLE_API_KEY=...
RAG_CONFIG_PATH=../config.yaml
PADDLEOCR_OUTPUT_DIR=../data/output
PADDLEOCRVL_DISABLE_VLLM=false
PADDLEOCRVL_AUTO_START_VLLM=true
PADDLEOCRVL_OFFLINE_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-vl:latest-nvidia-gpu-sm120-offline
PADDLEOCRVL_SERVER_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-genai-vllm-server:latest-nvidia-gpu-sm120

# Optional. Used only when <stem>.json and <stem>.md are missing.
# PADDLEOCR_COMMAND=powershell -ExecutionPolicy Bypass -File ../scripts/1_run_paddleocr.ps1 --file "{input}" --output-dir "{output_dir}"
