        },
        {
            "block_label": "text",
            "block_content": "The core components of our Liquidity Risk Management Framework are the Required Liquidity Framework, Liquidity Stress Tests and Liquidity Resources, which support our target liquidity profile. For a further discussion about the Firm's Required Liquidity Framework and Liquidity Stress Tests, see \"Management's Discussion and Analysis of Financial Condition and Results of Operations—Liquidity and Capital Resources—Liquidity Risk Management Framework\" in the 2025 Form 10-K.",
            "block_bbox": [
                627,
                381,
                1139,
                601
            ],
            "block_id": 15,
            "block_order": 12,
            "group_id": 15,
            "block_polygon_points": [
