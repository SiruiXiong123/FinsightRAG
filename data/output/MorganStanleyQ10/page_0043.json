                    83.0,
                    594.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "A description of the clients and principal products and services of each of the Firm's business segments is below. Through the Integrated Firm some of our clients may use the products and services of more than one of our business segments.",
            "block_bbox": [
                83,
                609,
                594,
                733
            ],
            "block_id": 6,
            "block_order": 5,
            "group_id": 6,
            "block_polygon_points": [
                [
                    83.0,
