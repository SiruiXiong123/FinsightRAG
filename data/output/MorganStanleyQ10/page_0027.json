        {
            "block_label": "paragraph_title",
            "block_content": "Attribution of Average Common Equity According to the Required Capital Framework",
            "block_bbox": [
                84,
                836,
                592,
                886
            ],
            "block_id": 6,
            "block_order": 6,
            "group_id": 6,
