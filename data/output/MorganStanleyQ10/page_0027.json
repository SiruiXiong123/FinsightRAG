        {
            "block_label": "text",
            "block_content": "We are required to submit once every two years to the Federal Reserve and the FDIC a resolution plan that describes our strategy for a rapid and orderly resolution under the U.S. Bankruptcy Code in the event of our material financial distress or failure. We submitted our 2025 targeted resolution plan on June 30, 2025.",
            "block_bbox": [
                627,
                541,
                1138,
                690
            ],
            "block_id": 14,
            "block_order": 12,
            "group_id": 14,
            "block_polygon_points": [
