        {
            "block_label": "paragraph_title",
            "block_content": "G-SIB Surcharge Proposal",
            "block_bbox": [
                630,
                556,
                864,
                581
            ],
            "block_id": 12,
            "block_order": 11,
            "group_id": 12,
            "block_polygon_points": [
