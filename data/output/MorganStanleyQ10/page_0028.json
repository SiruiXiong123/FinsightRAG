        },
        {
            "block_label": "paragraph_title",
            "block_content": "Supervisory Stress Testing",
            "block_bbox": [
                85,
                740,
                313,
                766
            ],
            "block_id": 6,
            "block_order": 5,
            "group_id": 6,
            "block_polygon_points": [
