                ],
                [
                    627.0,
                    839.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "For additional information on DCP, refer to “Other Matters” herein and Note 2 to the financial statements.",
            "block_bbox": [
                626,
                855,
                1138,
                907
            ],
            "block_id": 15,
            "block_order": 14,
            "group_id": 15,
            "block_polygon_points": [
