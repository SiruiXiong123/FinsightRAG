        {
            "block_label": "text",
            "block_content": "For more information on economic and market conditions, and the potential effects of geopolitical events on our future results, refer to “Risk Factors” and “Forward-Looking Statements” in the 2025 Form 10-K.",
            "block_bbox": [
                82,
                451,
