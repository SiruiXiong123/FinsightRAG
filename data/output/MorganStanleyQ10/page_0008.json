                    83.0,
                    320.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "We are monitoring the ongoing military conflict in the Middle East and its impact on the regional economy, global economic conditions, and financial markets. Our direct exposure to the region is limited.",
