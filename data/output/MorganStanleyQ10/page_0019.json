        {
            "block_label": "text",
            "block_content": "The Financial Accounting Standards Board has issued certain accounting updates that apply to us. Accounting updates not referenced below were assessed and determined to be either not applicable or to not have a material impact on our financial statements upon adoption.",
            "block_bbox": [
                84,
                148,
                595,
                272
            ],
            "block_id": 4,
